<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9
                  http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">


    <!-- Add scheduling configuration fields to sync_fhir_profile table -->
    <changeSet id="20240501-add-profile-scheduling-fields" author="slubwama">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sync_fhir_profile"/>
        </preConditions>

        <!-- Scheduling Configuration -->
        <addColumn tableName="sync_fhir_profile">
            <column name="schedule_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="true"/>
            </column>
            <column name="schedule_type" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="cron_expression" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="fixed_rate_interval" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="fixed_delay_interval" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="start_date_time" type="DATETIME">
                <constraints nullable="true"/>
            </column>
            <column name="end_date_time" type="DATETIME">
                <constraints nullable="true"/>
            </column>
            <column name="max_retry_attempts" type="INT" defaultValueNumeric="3">
                <constraints nullable="true"/>
            </column>
            <column name="retry_interval" type="BIGINT" defaultValueNumeric="60000">
                <constraints nullable="true"/>
            </column>
            <column name="timeout_duration" type="BIGINT" defaultValueNumeric="300000">
                <constraints nullable="true"/>
            </column>
            <column name="parallel_execution" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="true"/>
            </column>
            <column name="execution_priority" type="INT" defaultValueNumeric="5">
                <constraints nullable="true"/>
            </column>

            <!-- Task Configuration -->
            <column name="task_name" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="task_description" type="VARCHAR(1000)">
                <constraints nullable="true"/>
            </column>
            <column name="task_group" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>

            <!-- Execution Tracking -->
            <column name="last_execution_date" type="DATETIME">
                <constraints nullable="true"/>
            </column>
            <column name="next_execution_date" type="DATETIME">
                <constraints nullable="true"/>
            </column>
            <column name="last_execution_status" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="total_executions" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>
            <column name="successful_executions" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>
            <column name="failed_executions" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>
            <column name="average_execution_time" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>
            <column name="last_execution_error" type="VARCHAR(2000)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <rollback>
            <!-- Drop columns -->
            <dropColumn tableName="sync_fhir_profile" columnName="schedule_enabled"/>
            <dropColumn tableName="sync_fhir_profile" columnName="schedule_type"/>
            <dropColumn tableName="sync_fhir_profile" columnName="cron_expression"/>
            <dropColumn tableName="sync_fhir_profile" columnName="fixed_rate_interval"/>
            <dropColumn tableName="sync_fhir_profile" columnName="fixed_delay_interval"/>
            <dropColumn tableName="sync_fhir_profile" columnName="start_date_time"/>
            <dropColumn tableName="sync_fhir_profile" columnName="end_date_time"/>
            <dropColumn tableName="sync_fhir_profile" columnName="max_retry_attempts"/>
            <dropColumn tableName="sync_fhir_profile" columnName="retry_interval"/>
            <dropColumn tableName="sync_fhir_profile" columnName="timeout_duration"/>
            <dropColumn tableName="sync_fhir_profile" columnName="parallel_execution"/>
            <dropColumn tableName="sync_fhir_profile" columnName="execution_priority"/>
            <dropColumn tableName="sync_fhir_profile" columnName="task_name"/>
            <dropColumn tableName="sync_fhir_profile" columnName="task_description"/>
            <dropColumn tableName="sync_fhir_profile" columnName="task_group"/>
            <dropColumn tableName="sync_fhir_profile" columnName="last_execution_date"/>
            <dropColumn tableName="sync_fhir_profile" columnName="next_execution_date"/>
            <dropColumn tableName="sync_fhir_profile" columnName="last_execution_status"/>
            <dropColumn tableName="sync_fhir_profile" columnName="total_executions"/>
            <dropColumn tableName="sync_fhir_profile" columnName="successful_executions"/>
            <dropColumn tableName="sync_fhir_profile" columnName="failed_executions"/>
            <dropColumn tableName="sync_fhir_profile" columnName="average_execution_time"/>
            <dropColumn tableName="sync_fhir_profile" columnName="last_execution_error"/>
        </rollback>
    </changeSet>

    <!-- Create indexes for performance - separate changeSet -->
    <changeSet id="20240501-add-profile-indexes" author="slubwama">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sync_fhir_profile"/>
            <columnExists tableName="sync_fhir_profile" columnName="schedule_enabled"/>
        </preConditions>

        <!-- Add indexes for performance -->
        <createIndex tableName="sync_fhir_profile" indexName="idx_schedule_enabled" unique="false">
            <column name="schedule_enabled"/>
        </createIndex>

        <createIndex tableName="sync_fhir_profile" indexName="idx_task_group" unique="false">
            <column name="task_group"/>
        </createIndex>

        <createIndex tableName="sync_fhir_profile" indexName="idx_last_execution_status" unique="false">
            <column name="last_execution_status"/>
        </createIndex>

        <rollback>
            <!-- Drop indexes -->
            <dropIndex tableName="sync_fhir_profile" indexName="idx_schedule_enabled"/>
            <dropIndex tableName="sync_fhir_profile" indexName="idx_task_group"/>
            <dropIndex tableName="sync_fhir_profile" indexName="idx_last_execution_status"/>
        </rollback>
    </changeSet>

    <!-- Create execution history table -->
    <changeSet id="20240501-create-profile-execution-history" author="slubwama">
        <createTable tableName="sync_fhir_profile_execution_history">
            <column name="execution_history_id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="sync_fhir_profile_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="execution_start_time" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="execution_end_time" type="DATETIME">
                <constraints nullable="true"/>
            </column>
            <column name="execution_status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="resources_generated" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="cases_processed" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="execution_duration_ms" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="error_message" type="VARCHAR(2000)">
                <constraints nullable="true"/>
            </column>
            <column name="stack_trace" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="uuid" type="CHAR(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="creator" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="date_created" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="changed_by" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="date_changed" type="DATETIME">
                <constraints nullable="true"/>
            </column>
            <column name="voided" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="voided_by" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="date_voided" type="DATETIME">
                <constraints nullable="true"/>
            </column>
            <column name="void_reason" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <!-- Add foreign key constraint -->
        <addForeignKeyConstraint
                baseTableName="sync_fhir_profile_execution_history"
                baseColumnNames="sync_fhir_profile_id"
                referencedTableName="sync_fhir_profile"
                referencedColumnNames="sync_fhir_profile_id"
                constraintName="fk_execution_history_profile"
                onDelete="CASCADE"/>

        <!-- Add indexes for performance -->
        <createIndex tableName="sync_fhir_profile_execution_history" indexName="idx_execution_history_profile" unique="false">
            <column name="sync_fhir_profile_id"/>
        </createIndex>

        <createIndex tableName="sync_fhir_profile_execution_history" indexName="idx_execution_history_status" unique="false">
            <column name="execution_status"/>
        </createIndex>

        <createIndex tableName="sync_fhir_profile_execution_history" indexName="idx_execution_history_start_time" unique="false">
            <column name="execution_start_time"/>
        </createIndex>

        <createIndex tableName="sync_fhir_profile_execution_history" indexName="idx_execution_history_date_created" unique="false">
            <column name="date_created"/>
        </createIndex>

        <rollback>
            <dropTable tableName="sync_fhir_profile_execution_history"/>
        </rollback>
    </changeSet>

    <changeSet id="ugandaemrsync-add-custom-task-class-to-profile-2024-05-02" author="slubwama">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sync_fhir_profile"/>
            <not>
                <columnExists tableName="sync_fhir_profile" columnName="custom_task_class"/>
            </not>
        </preConditions>

        <comment>
            Add custom_task_class column to sync_fhir_profile table.
            This allows profiles to specify custom task classes for specialized execution logic.
            If left NULL, the profile will be executed by the GenericFhirProfileSchedulerTask.
        </comment>

        <addColumn tableName="sync_fhir_profile">
            <column name="custom_task_class" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="sync_fhir_profile" columnName="custom_task_class"/>
        </rollback>
    </changeSet>

    <changeSet id="ugandaemrsync-create-generic-fhir-profile-task-2024-05-02" author="slubwama">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="scheduler_task_config"/>
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM scheduler_task_config
                WHERE schedulable_class = 'org.openmrs.module.ugandaemrsync.tasks.GenericFhirProfileSchedulerTask'
            </sqlCheck>
        </preConditions>

        <comment>
            Insert the Generic FHIR Profile Scheduler Task configuration.
            This single task can execute multiple FHIR profiles based on database configuration.
            Runs every 5 minutes by default to check for enabled profiles that need execution.
        </comment>

        <insert tableName="scheduler_task_config">
            <column name="name" value="Generic FHIR Profile Scheduler"/>
            <column name="description" value="Executes enabled FHIR profiles based on database configuration. Supports both case-based and resource-based profiles with automatic retry and error tracking."/>
            <column name="schedulable_class" value="org.openmrs.module.ugandaemrsync.tasks.GenericFhirProfileSchedulerTask"/>
            <column name="start_time_pattern" value="MM/dd/yyyy HH:mm:ss" />
            <column name="start_time" valueDate="2026-01-01T00:00:00"/>
            <column name="repeat_interval" value="300000"/>
            <column name="started" value="1"/>
            <column name="created_by" value="1"/>
            <column name="date_created" valueDate="2026-01-01T00:00:00"/>
            <column name="uuid" value="bebe701a-4614-11f1-8bc7-4e0a484b9f3b"/>
        </insert>
    </changeSet>

    <changeSet id="ugandaemrsync-20260507-rename-hiv-surveillance" author="slubwama1">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM scheduler_task_config WHERE uuid = '56db6ac0-0e60-4ddc-8dfd-0035a4e64489'
            </sqlCheck>
        </preConditions>
        <comment>Renaming HIV CASE BASED SURVEILLANCE task to National Data Ware House</comment>
        <update tableName="scheduler_task_config">
            <column name="name" value="National Data Ware House"/>
            <column name="description" value="The National Data Ware House task"/>
            <column name="schedulable_class" value="org.openmrs.module.ugandaemrsync.tasks.NationalDataWareHouseTask"/>
            <where>uuid = '56db6ac0-0e60-4ddc-8dfd-0035a4e64489'</where>
        </update>
    </changeSet>

    <changeSet id="ugandaemrsync-20260507-rename-hiv-surveillance-profile" author="slubwama1">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM sync_fhir_profile WHERE uuid = '6511be5a-72f2-4638-a60b-78e31c3e2b28'
            </sqlCheck>
        </preConditions>
        <comment>Renaming HIV CASE BASED SURVEILLANCE FHIR profile to National Data Ware House</comment>
        <update tableName="sync_fhir_profile">
            <column name="name" value="National Data Ware House"/>
            <where>uuid = '6511be5a-72f2-4638-a60b-78e31c3e2b28'</where>
        </update>
    </changeSet>

</databaseChangeLog>